# ═══════════════════════════════════════════════
# WorldView — Environment Configuration
# Copy to .env and fill in your API keys
# ═══════════════════════════════════════════════

# ─── Inference Stack ───────────────────────────────────────────────────────
# Pfad zum lokalen Modell-Verzeichnis (für vLLM Volume-Mount in docker-compose)
MODELS_PATH=/home/deadpool-ultra/ODIN/models

# ─── Neo4j ─────────────────────────────────────────────────────────────────
NEO4J_PASSWORD=odin1234
NEO4J_USER=neo4j
NEO4J_URL=bolt://localhost:7687

# ─── HuggingFace ───────────────────────────────────────────────────────────
# Optional — erhöht Download-Rate-Limit für TEI-Modelle
HF_TOKEN=

# ── Google / Cesium ──
CESIUM_ION_TOKEN=your_cesium_ion_token_here
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── Flight Data ──
OPENSKY_USER=                    # Optional: erhöht Rate-Limits
OPENSKY_PASS=

# ── Ship Data ──
AISSTREAM_API_KEY=your_aisstream_key_here

# ── CCTV / Webcams ──
WINDY_API_KEY=your_windy_key_here

# ── LLM / Embeddings ───────────────────────────────────────────────────────
# Compose überschreibt die Service-URLs intern auf vllm/tei-embed/tei-rerank.
# Diese Defaults sind für lokale Entwicklung außerhalb von Compose.
INFERENCE_PROVIDER=vllm
VLLM_MODEL=qwen3.5
VLLM_URL=http://localhost:8000
TEI_EMBED_URL=http://localhost:8001
TEI_RERANK_URL=http://localhost:8002
EMBEDDING_DIMENSIONS=1024
FLIGHT_CACHE_TTL_S=30

# ── Internal (usually no change needed) ──
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333

# ─── NotebookLM / Voxtral ──────────────────────────────────────────────────
# Voxtral model path for audio transcription service
VOXTRAL_MODEL_PATH=/home/deadpool-ultra/Voxtral/model

# ─── Telegram Collector ───────────────────────────────────────────────────
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ─── Vision Enrichment (Qwen3-VL-8B) ─────────────────────────────────────
VISION_VLLM_MODEL=qwen-vl

# --- Hugin P0 Collectors ---
NASA_EARTHDATA_KEY=
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
UCDP_ACCESS_TOKEN=

# Ingestion LLM (Spark — eliminates GPU swap on RTX 5090)
INGESTION_VLLM_URL=http://192.168.178.39:8000
INGESTION_VLLM_MODEL=Qwen/Qwen3.6-35B-A3B
INGESTION_VLLM_TIMEOUT=120.0
