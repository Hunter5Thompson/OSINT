# ═══════════════════════════════════════════════
# WorldView — Environment Configuration
# Copy to .env and fill in your API keys
# ═══════════════════════════════════════════════

# ── Google / Cesium ──
CESIUM_ION_TOKEN=your_cesium_ion_token_here
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── Flight Data ──
OPENSKY_USER=                    # Optional: erhöht Rate-Limits
OPENSKY_PASS=

# ── Ship Data ──
AISSTREAM_API_KEY=your_aisstream_key_here

# ── CCTV / Webcams ──
WINDY_API_KEY=your_windy_key_here

# ── LLM Inference ──
INFERENCE_PROVIDER=ollama        # "ollama" or "vllm"
OLLAMA_MODEL=qwen3:32b
VLLM_MODEL=Qwen/Qwen3-32B
EMBEDDING_MODEL=nomic-embed-text

# ── Internal (usually no change needed) ──
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
OLLAMA_URL=http://localhost:11434
VLLM_URL=http://localhost:8001
